# Supabase (클라이언트용, 앱에 번들됨)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# OpenAI (L1~L4 AI 파이프라인) — Supabase Edge Function 환경변수로만 설정
# OPENAI_API_KEY=sk-your-openai-key

# PortOne Payment (클라이언트용 store/channel만)
EXPO_PUBLIC_PORTONE_STORE_ID=your-store-id
EXPO_PUBLIC_PORTONE_CHANNEL_KEY=your-channel-key
# PORTONE_API_SECRET=your-api-secret  (Edge Function env only)

# Resend Email — Edge Function env only
# RESEND_API_KEY=re_your-resend-key

# ⚠️ 보안 주의: OPENAI_API_KEY, ANTHROPIC_API_KEY, SUPABASE_SERVICE_ROLE_KEY,
# PORTONE_API_SECRET, RESEND_API_KEY 등 서버 전용 키는 절대 모바일 앱에 포함하지 마세요.
# 이 키들은 Supabase Edge Function 환경변수로만 설정합니다.
